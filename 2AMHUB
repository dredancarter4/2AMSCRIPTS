local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer

-- Main UI
local function createMainUI()
    local screenGui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
    screenGui.Name = "2AMHUB_UI"

    local mainFrame = Instance.new("Frame", screenGui)
    mainFrame.Size = UDim2.new(0, 520, 0, 520)
    mainFrame.Position = UDim2.new(0, 10, 0, 60)
    mainFrame.BackgroundColor3 = Color3.fromRGB(9, 11, 16)
    mainFrame.BackgroundTransparency = 0.08
    mainFrame.BorderSizePixel = 0
    mainFrame.ZIndex = 10
    Instance.new("UICorner", mainFrame).CornerRadius = UDim.new(0, 20)

    -- Title bar
    local titleBar = Instance.new("Frame", mainFrame)
    titleBar.Size = UDim2.new(1, 0, 0, 48)
    titleBar.BackgroundColor3 = Color3.fromRGB(13, 16, 23)
    titleBar.BorderSizePixel = 0
    titleBar.ZIndex = 11
    Instance.new("UICorner", titleBar).CornerRadius = UDim.new(0, 20)

    local titleLabel = Instance.new("TextLabel", titleBar)
    titleLabel.Size = UDim2.new(0.5, 0, 1, 0)
    titleLabel.Position = UDim2.new(0, 20, 0, 0)
    titleLabel.BackgroundTransparency = 1
    titleLabel.Text = "2AMHUB"
    titleLabel.Font = Enum.Font.GothamBlack
    titleLabel.TextSize = 14
    titleLabel.TextColor3 = Color3.fromRGB(220, 225, 235)
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left

    -- Close button
    local closeBtn = Instance.new("TextButton", titleBar)
    closeBtn.Size = UDim2.new(0, 30, 0, 30)
    closeBtn.Position = UDim2.new(1, -40, 0, 9)
    closeBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    closeBtn.Text = "×"
    closeBtn.Font = Enum.Font.GothamBold
    closeBtn.TextSize = 16
    closeBtn.TextColor3 = Color3.new(1,1,1)
    closeBtn.BorderSizePixel = 0
    closeBtn.ZIndex = 12
    Instance.new("UICorner", closeBtn).CornerRadius = UDim.new(1, 0)
    closeBtn.MouseButton1Click: = function() mainFrame.Visible = false end

    -- Make draggable
    local function makeDraggable(frame, handle)
        handle = handle or frame
        local dragging, startPos, startOffset
        handle.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                startPos = Vector2.new(input.Position.X, input.Position.Y)
                startOffset = Vector2.new(frame.Position.X.Offset, frame.Position.Y.Offset)
            end
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = false
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if dragging and startPos then
                local dx = input.Position.X - startPos.X
                local dy = input.Position.Y - startPos.Y
                frame.Position = UDim2.new(0, startOffset.X + dx, 0, startOffset.Y + dy)
            end
        end)
    end
    makeDraggable(mainFrame, titleBar)

    -- Tab buttons (Move, Combat, Visual, Settings, Keys)
    local tabNames = {"Move", "Combat", "Visual", "Settings", "Keys"}
    local tabButtons = {}
    local tabContents = {}

    local tabHolder = Instance.new("Frame", mainFrame)
    tabHolder.Size = UDim2.new(1, 0, 1, -48)
    tabHolder.Position = UDim2.new(0, 0, 0, 48)
    tabHolder.BackgroundTransparency = 1

    local sidebar = Instance.new("Frame", tabHolder)
    sidebar.Size = UDim2.new(0, 120, 1, 0)
    sidebar.Position = UDim2.new(0, 0, 0, 0)
    sidebar.BackgroundColor3 = Color3.fromRGB(13, 16, 23)
    sidebar.BorderSizePixel = 0

    local contentFrame = Instance.new("Frame", tabHolder)
    contentFrame.Size = UDim2.new(1, -120, 1, 0)
    contentFrame.Position = UDim2.new(0, 120, 0, 0)
    contentFrame.BackgroundTransparency = 1

    -- Create tab buttons
    for i, name in ipairs(tabNames) do
        local btn = Instance.new("TextButton", sidebar)
        btn.Size = UDim2.new(1, 0, 0, 40)
        btn.Position = UDim2.new(0, 0, (i-1)*40, 0)
        btn.BackgroundColor3 = Color3.fromRGB(0,0,0)
        btn.Text = name
        btn.Font = Enum.Font.GothamBlack
        btn.TextSize = 10
        btn.TextColor3 = Color3.fromRGB(150,150,150)
        btn.BorderSizePixel = 0
        btn.ZIndex = 12

        -- Content for each tab
        local tabContent = Instance.new("Frame", contentFrame)
        tabContent.Size = UDim2.new(1,0,1,0)
        tabContent.BackgroundTransparency = 1
        tabContent.Visible = false
        tabContents[name] = tabContent

        -- Button click
        btn.MouseButton1Click: = function()
            for n, frame in pairs(tabContents) do
                frame.Visible = (n == name)
            end
            for _, b in pairs(sidebar:GetChildren()) do
                if b:IsA("TextButton") then
                    b.TextColor3 = (b == btn) and Color3.fromRGB(255,255,255) or Color3.fromRGB(150,150,150)
                end
            end
        end
    end

    -- Initialize first tab as active
    local firstTab = tabContents["Move"]
    firstTab.Visible = true
    for _, b in pairs(sidebar:GetChildren()) do
        if b:IsA("TextButton") then
            b.TextColor3 = (b == sidebar:FindFirstChild("Move")) and Color3.fromRGB(255,255,255) or Color3.fromRGB(150,150,150)
        end
    end

    -- Add simple sample content to "Move" tab
    local moveTab = tabContents["Move"]
    local label = Instance.new("TextLabel", moveTab)
    label.Size = UDim2.new(1, -20, 0, 50)
    label.Position = UDim2.new(0, 10, 0, 10)
    label.Text = "This is the Move tab"
    label.TextColor3 = Color3.fromRGB(220, 225, 235)
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.GothamBlack
    label.TextSize = 14

    -- You can add more UI elements to each tab content as needed

end

-- Call to create the UI
createMainUI()

-- Toggle main UI with U key
local mainUIVisible = true
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.U then
        mainUIVisible = not mainUIVisible
        local mainGui = game:GetService("CoreGui"):FindFirstChild("2AMHUB_UI") or game:GetService("Players").LocalPlayer.PlayerGui:FindFirstChild("2AMHUB_UI")
        if mainGui then
            mainGui.Enabled = mainUIVisible
        end
    end
end)

--// SERVICES
local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

--// THEME (UPGRADED)
local TH = {
    bg       = Color3.fromRGB(6, 8, 12),
    panel    = Color3.fromRGB(12, 14, 20),
    panel2   = Color3.fromRGB(18, 20, 28),
    panel3   = Color3.fromRGB(25, 28, 38),

    accent   = Color3.fromRGB(0, 255, 200),
    accent2  = Color3.fromRGB(0, 180, 255),

    text     = Color3.fromRGB(235, 240, 255),
    muted    = Color3.fromRGB(120, 130, 150),
}

--// GUI
local gui = Instance.new("ScreenGui")
gui.Name = "2AMHUB"
gui.ResetOnSpawn = false
gui.Parent = playerGui

--// MAIN FRAME
local main = Instance.new("Frame", gui)
main.Size = UDim2.new(0, 420, 0, 300)
main.Position = UDim2.new(0.5, -210, 0.5, -150)
main.BackgroundColor3 = TH.panel

--// STYLE FUNCTION (NEW)
local function style(obj)
    local c = Instance.new("UICorner", obj)
    c.CornerRadius = UDim.new(0, 10)

    local s = Instance.new("UIStroke", obj)
    s.Color = TH.accent
    s.Transparency = 0.4

    local g = Instance.new("UIGradient", obj)
    g.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, TH.panel2),
        ColorSequenceKeypoint.new(1, TH.panel3)
    }
end

style(main)

--// TITLE (UPDATED NAME)
local title = Instance.new("TextLabel", main)
title.Size = UDim2.new(1, 0, 0, 40)
title.BackgroundTransparency = 1
title.Text = "2AMHUB | By 2AMDredan"
title.Font = Enum.Font.GothamBlack
title.TextSize = 20
title.TextColor3 = TH.accent

--// DRAGGING (OPTIMIZED)
local dragging, dragInput, dragStart, startPos

main.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = main.Position

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

main.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement then
        dragInput = input
    end
end)

RunService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        main.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
end)

--// BUTTON EFFECT (NEW)
local function buttonEffect(btn)
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), {
            BackgroundColor3 = TH.accent
        }):Play()
    end)

    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), {
            BackgroundColor3 = TH.panel2
        }):Play()
    end)
end

--// BUTTON CREATOR (KEEPS STRUCTURE BUT CLEANER)
local function createButton(text, posY, callback)
    local btn = Instance.new("TextButton", main)
    btn.Size = UDim2.new(0.8, 0, 0, 40)
    btn.Position = UDim2.new(0.1, 0, 0, posY)
    btn.BackgroundColor3 = TH.panel2
    btn.Text = text
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 16
    btn.TextColor3 = TH.text

    style(btn)
    buttonEffect(btn)

    if callback then
        btn.MouseButton1Click:Connect(callback)
    end

    return btn
end

--// CHARACTER CACHE (OPTIMIZED)
local humanoid
local function getHumanoid()
    local char = player.Character or player.CharacterAdded:Wait()
    if not humanoid or humanoid.Parent ~= char then
        humanoid = char:WaitForChild("Humanoid")
    end
    return humanoid
end

--// ORIGINAL-LIKE FEATURES (KEPT SIMPLE BUT SAME IDEA)
createButton("Speed Boost", 60, function()
    getHumanoid().WalkSpeed = 50
end)

createButton("Jump Boost", 110, function()
    getHumanoid().JumpPower = 100
end)

createButton("Reset Character", 160, function()
    player.Character:BreakJoints()
end)

--// SAFE HEARTBEAT (NO LAG)
RunService.Heartbeat:Connect(function()
